{
  "disk": {
    "tooltip": false,
    "interval": 3600,
    "path": "/",
    "format": "󱙋",
    "format-alt": "󱙋 <span size='11pt'>{used}</span>",
    "states": {
      "warning": 80,
      "critical": 90
    }
  },
  "memory": {
    "tooltip": false,
    "interval": 15,
    "format": "󰍛",
    "format-alt": "󰍛 <span size='11pt'>{used}</span>",
    "states": {
      "warning": 75,
      "critical": 85
    }
  }
}
