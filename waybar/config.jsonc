  "modules-left": ["group/distro-group", "group/storage", "group/system"],
  "modules-center": [
    "power-profiles-daemon",
    "hyprland/workspaces",
    "idle_inhibitor",
  ],
  "modules-right": [
    "group/backlight",
    "group/audio",
    "group/connections",
    "battery",
    "clock",
    "group/tray-group",
  ],
